{
  "project_type": "eval-harness",
  "rubric": "eval-harness",
  "max_retries": 3,
  "pass_threshold": {
    "per_dimension_minimum": 2,
    "critical_dimensions": ["methodology_completeness", "generator_evaluator_separation"],
    "critical_minimum": 3
  },
  "contract_negotiation_rounds": 2,
  "git_checkpoint": true,
  "components_enabled": {
    "planner": true,
    "contract_negotiation": true,
    "sprint_decomposition": true,
    "eval_summary": true
  },
  "trials": 1,
  "sandbox": {
    "mode": "none"
  },
  "taxonomy": {
    "emit_tasks_json": true
  },
  "regression": {
    "enabled": null,
    "fail_fast": true
  },
  "thinking": {
    "profile": "default"
  },
  "batch": {
    "enabled": false,
    "min_criteria": 20
  },
  "transcripts": {
    "capture": true,
    "retain_days": 30
  },
  "evaluator_tools": {
    "playwright": "auto"
  },
  "python_build": {
    "project_root": ".",
    "src_root": "src/trine_eval",
    "test_command": "uv run pytest",
    "lint_command": "uv run ruff check && uv run mypy --strict src",
    "python_version": "3.12",
    "lock_file_path": "uv.lock"
  }
}
